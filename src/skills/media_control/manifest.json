{
  "name": "media_control",
  "type": "hybrid",
  "confirmation": false,

  "intents": {
    "playaudio": {
      "required_entities": ["play"],
      "entity_schema": {
        "play":{
          "type":"free"
        }
      }
    },
    "setvolume": {
      "required_entities": ["value"],
      "entity_schema": {
        "value":{
          "type":"enum",
          "values": [1,2,3,4,5]
        }
      }
    },
    "volumeup": {},
    "volumedown": {},
    "pauseaudio": {},
    "resumeaudio": {},
    "nexttrack": {},
    "previoustrack": {}
  }
}